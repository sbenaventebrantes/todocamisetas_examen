{
  "info": {
    "name": "TodoCamisetas API",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "Customers",
      "item": [
        {"name": "List customers", "request": {"method": "GET", "url": "{{baseUrl}}/customers"}},
        {"name": "Create customer", "request": {"method": "POST", "url": "{{baseUrl}}/customers"}}
      ]
    },
    {
      "name": "Shirts",
      "item": [
        {"name": "List shirts", "request": {"method": "GET", "url": "{{baseUrl}}/shirts"}},
        {"name": "Show shirt", "request": {"method": "GET", "url": "{{baseUrl}}/shirts/1?customerId=1"}}
      ]
    },
    {
      "name": "Sizes",
      "item": [
        {"name": "List sizes", "request": {"method": "GET", "url": "{{baseUrl}}/sizes"}}
      ]
    }
  ],
  "variable": [
    {"key": "baseUrl", "value": "http://127.0.0.1:8000/api"}
  ]
}
